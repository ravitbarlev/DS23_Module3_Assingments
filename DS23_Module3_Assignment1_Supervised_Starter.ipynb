y_test_residuals = y_test - baseline_test

# 5. הגדרת מודל ה-XGBoost המכוונן שלך
xgb_residual_model = XGBRegressor(
    n_estimators=500,
    max_depth=3,
    learning_rate=0.03,
    subsample=0.8,
    colsample_bytree=0.8,
